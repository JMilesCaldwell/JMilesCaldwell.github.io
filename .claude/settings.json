{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push -u origin claude/*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(find . *)",
      "Bash(mkdir -p .claude)"
    ],
    "deny": [
      "Bash(git push*origin main*)",
      "Bash(git push --force*)",
      "Bash(rm -rf*)"
    ]
  }
}
